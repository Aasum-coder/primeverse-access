# Required for the dashboard, public landing pages, and all API routes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by API routes that bypass RLS for admin reads/writes
# (inbound webhook, voice profile API, etc).
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email + inbound parsing.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Anthropic — used by /api/ai-bio, /api/ai-marketing, and the My Voice
# endpoints (bio generation, system-prompt synthesis, translations).
ANTHROPIC_API_KEY=

# Groq — used by /api/ai-marketing (Post Writer, etc.) and the My Voice
# /ai-suggest endpoint.
GROQ_API_KEY=

# Notion — used by scripts/sync-notion-pdf.ts in the GitHub Actions workflow
# (not consumed at runtime; lives in GitHub Secrets, not Vercel env).
# NOTION_API_KEY=

# Meta Developer App (Instagram + Facebook Pages auto-posting).
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
